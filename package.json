{
	"name": "@xl0/show-sysprompt",
	"version": "0.1.7",
	"keywords": [
		"pi-package"
	],
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/JosiahEverson/pi-agent-show-sysprompt#readme",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/JosiahEverson/pi-agent-show-sysprompt.git"
	},
	"files": [
		"extensions/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"typecheck": "tsgo --noEmit",
		"check": "bun run typecheck && bun run biome:check",
		"release": "bun publish --access public",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"biome:check": "biome check ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@typescript/native-preview": "^7.0.0-dev.20260502.1",
		"bun-types": "^1.3.13",
		"typescript": "^6.0.3",
		"@earendil-works/pi-coding-agent": "0.80.7",
		"@earendil-works/pi-tui": "0.80.7",
		"typebox": "1.1.38"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"pi": {
		"extensions": [
			"./extensions"
		],
		"image": "https://raw.githubusercontent.com/JosiahEverson/pi-agent-show-sysprompt/master/screenshot.png",
		"video": "https://raw.githubusercontent.com/JosiahEverson/pi-agent-show-sysprompt/master/demo.mp4"
	}
}
